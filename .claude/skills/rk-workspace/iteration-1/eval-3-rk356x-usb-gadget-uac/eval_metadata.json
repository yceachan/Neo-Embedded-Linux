{
  "eval_id": 3,
  "eval_name": "rk356x-usb-gadget-uac",
  "prompt": "我想把 RK3568 当成 USB 音频设备(UAC2 麦克风 + 扬声器),通过 OTG 口接电脑。SDK 里有现成方案吗? 大致流程是什么? 涉及哪些 PDF?",
  "assertions": [
    {
      "id": "mentions_uac2",
      "text": "答案明确提到 UAC2 协议名",
      "verifier": "regex_in_answer",
      "pattern": "UAC ?2"
    },
    {
      "id": "mentions_configfs_or_gaudio",
      "text": "答案至少给出 ConfigFS 配置或 g_audio 模块两种实现路径之一",
      "verifier": "regex_in_answer",
      "pattern": "(ConfigFS|configfs|g_audio|f_uac2)"
    },
    {
      "id": "mentions_kconfig",
      "text": "答案提及相关内核 Kconfig 项",
      "verifier": "regex_in_answer",
      "pattern": "(CONFIG_USB_(CONFIGFS_F_)?UAC2|CONFIG_USB_F_UAC2|CONFIG_USB_AUDIO)"
    },
    {
      "id": "cites_usb_uac_pdf",
      "text": "答案/trace 引用 USB_Gadget_UAC PDF",
      "verifier": "regex_in_trace_or_answer",
      "pattern": "USB_Gadget_UAC|Gadget.{0,5}UAC"
    },
    {
      "id": "multi_pdf_synthesis",
      "text": "[with_skill only] trace 表明综合了 ≥2 份 PDF (e.g. USB Gadget UAC + Quick Start USB Gadget 或 USB 通用)",
      "verifier": "manual_count_trace_pdfs",
      "pattern": "\\.pdf"
    },
    {
      "id": "skill_wrote_distilled",
      "text": "[with_skill only] 在 references/distilled/ 下创建了 UAC 相关的蒸馏文件",
      "verifier": "file_exists_glob",
      "pattern": "/home/pi/imx/.claude/skills/rk/references/distilled/*uac*.md"
    }
  ]
}
